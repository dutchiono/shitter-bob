# =============================================================
# .env.example — copy to .env and fill in values
# NEVER commit .env to git
# =============================================================

# --- Solana / Helius ---
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_API_KEY=YOUR_HELIUS_API_KEY

# --- Bob's wallet ---
# Store as JSON byte array: [1,2,3,...,64]
# Generate with: solana-keygen new --outfile bob-wallet.json
# Then: cat bob-wallet.json
BOB_PRIVATE_KEY=[1,2,3,4,...]

# --- Dev wallet (sweep destination) ---
# READ-ONLY — never used as signing key
DEV_WALLET_ADDRESS=YOUR_DEV_WALLET_PUBLIC_KEY

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- ElevenLabs TTS (optional) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- X / Twitter ---
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# --- Database ---
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://bob:change_me_strong_password@db:5432/shitterbob

# --- Supabase (optional, for public dashboard) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Healthchecks.io ---
HEALTHCHECKS_PING_URL=https://hc-ping.com/YOUR_UUID
